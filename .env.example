# Database — PostgreSQL
# Prisma uses DATABASE_URL for queries and DIRECT_URL for migrations (same value unless you use a pooler).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"

# Remote / production (replace host and port with your provider):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Optional local Postgres (docker compose up -d db) — see docker-compose.yml:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/storybook"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/storybook"

# Auth — generate a random secret: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# App URL (local dev)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable Google login)
# Canonical names (preferred):
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Legacy aliases also supported: GOOGLE_ID / GOOGLE_SECRET

# Upstash Redis (rate limit + realtime pub/sub — optional for local dev)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# AI — Groq primary, OpenRouter fallback (server routes only).
# Model IDs are hardcoded in src/lib/ai-provider.ts (multi-model shuffle chain).
# Only API keys are required on Vercel — no model env vars needed.
GROQ_API_KEY=""
OPENROUTER_API_KEY=""

# Anthropic AI Assist (optional legacy — used if Groq/OpenRouter unset)
ANTHROPIC_API_KEY=""

# Demo login picker on /login (optional — on by default for showcase)
# SHOW_DEMO_LOGIN="false"

# Voice dictation — optional Phase 3 cloud STT (server-side only; keys never sent to browser)
# Phase 1 (Web Speech API) and Phase 2 (browser Whisper) work with NO keys.
#
# Deepgram — https://console.deepgram.com/signup
#   Free: $200 one-time credit, no credit card; expires 1 year after signup
# AssemblyAI — https://www.assemblyai.com/dashboard/signup
#   Free: $50 one-time credit, no credit card; credits do not expire
#
# Set ONE key below, then expose the matching provider to the client picker:
DEEPGRAM_API_KEY=""
ASSEMBLYAI_API_KEY=""
# NEXT_PUBLIC_VOICE_PROVIDER="server-deepgram"
# NEXT_PUBLIC_VOICE_PROVIDER="server-assemblyai"
